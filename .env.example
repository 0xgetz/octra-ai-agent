# Octra Network AI Agent - Environment Configuration
# Copy this file to .env: cp .env.example .env

PORT=3000

# Allowed CORS origins (comma-separated) - restrict to your deployment domains
# Default allows localhost only
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Users provide their own API keys via the UI - no server-side keys needed
# NODE_ENV=production
