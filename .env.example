# Octra Network AI Agent - Environment Configuration
# Copy this file to .env: cp .env.example .env

PORT=3000

# Allowed CORS origins (comma-separated) - restrict to your deployment domains.
# Default allows localhost only. Use '*' to allow any origin (not recommended).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: directory for durable conversation/share persistence.
# If unset, conversations live in memory only (lost on restart).
# On serverless platforms use a writable path like /tmp (still ephemeral).
# PERSIST_DIR=./.data

# Users provide their own AI provider API keys via the UI (stored in the
# browser only) - no server-side keys are needed or stored.
# Supported providers: OpenAI, Claude, Gemini, Groq, OpenRouter.
# NODE_ENV=production
